# Email Configuration
# Gmail account credentials for sending reports
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
RECIPIENT_EMAIL=recipient@example.com

# Scraping Configuration
# Delay between requests in seconds (randomized between min and max)
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5

# Run browser in headless mode (true/false)
HEADLESS=true

# Feature Flags
# Enable yfinance enrichment for additional fund data
ENRICH_WITH_YFINANCE=true

# Send email reports (set to false for testing)
SEND_EMAIL=true

# Report frequency: daily or weekly
REPORT_FREQUENCY=weekly

# Dry run mode - scrape but don't save or send emails (true/false)
DRY_RUN=false